# OpenClaw Guard 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================
# 基础配置
# ============================================
TZ=Asia/Shanghai
GUARD_ENABLED=true

# ============================================
# 告警通知配置
# ============================================
# 飞书机器人 Webhook
ALERT_WEBHOOK_FEISHU=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_WEBHOOK_KEY

# 钉钉机器人 Webhook
ALERT_WEBHOOK_DINGTALK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN

# Slack Webhook
ALERT_WEBHOOK_SLACK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# 告警级别阈值 (info/warning/error/critical)
ALERT_LEVEL_THRESHOLD=warning

# ============================================
# 备份配置
# ============================================
# 增量快照保留时间（小时）
BACKUP_RETENTION_HOURS=48

# 每日归档保留天数
BACKUP_RETENTION_DAYS=7

# 每月归档保留月数
BACKUP_RETENTION_MONTHS=3

# 备份压缩（true/false）
BACKUP_COMPRESS=true

# ============================================
# Git 版本控制
# ============================================
GIT_AUTO_COMMIT=true
GIT_COMMIT_INTERVAL=5  # 分钟
GIT_USER_NAME=OpenClaw Guard
GIT_USER_EMAIL=guard@openclaw.local

# ============================================
# 健康检查配置
# ============================================
HEALTH_CHECK_INTERVAL=30  # 秒
HEALTH_CHECK_TIMEOUT=10   # 秒
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_ENDPOINT=http://localhost:3000/health

# ============================================
# 远程同步配置（可选）
# ============================================
# 启用远程同步
REMOTE_SYNC_ENABLED=false

# Rclone 远程名称（需先配置 rclone.conf）
RCLONE_REMOTE=s3:openclaw-backups

# 同步间隔（秒）
REMOTE_SYNC_INTERVAL=3600

# ============================================
# 多机热备配置（高级，可选）
# ============================================
# 启用热备模式
HA_MODE_ENABLED=false

# 主节点地址
HA_PRIMARY_HOST=openclaw-1.example.com

# 备节点地址（逗号分隔）
HA_BACKUP_HOSTS=openclaw-2.example.com,openclaw-3.example.com

# 共享 Redis 地址
HA_REDIS_URL=redis://redis-cluster:6379

# 共享 PostgreSQL 地址
HA_POSTGRES_URL=postgresql://user:pass@postgres:5432/openclaw

# ============================================
# Docker 资源限制
# ============================================
DOCKER_CPU_LIMIT=2
DOCKER_MEMORY_LIMIT=4G
DOCKER_CPU_RESERVATION=0.5
DOCKER_MEMORY_RESERVATION=512M

# ============================================
# 调试选项
# ============================================
DEBUG=false
LOG_LEVEL=info  # debug/info/warning/error
